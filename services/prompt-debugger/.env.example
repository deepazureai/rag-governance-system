# Prompt Debugger Service - Environment Configuration

# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/prompt-debugger

# LLM Provider Configuration
# Supported providers: claude, openai, deepseek, custom

# Claude (Anthropic)
LLM_PROVIDER=claude
LLM_MODEL=claude-opus-4-1-20250805
LLM_API_KEY=your-claude-api-key-here

# Alternative: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4-turbo
# LLM_API_KEY=your-openai-api-key-here

# Alternative: DeepSeek
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-coder
# LLM_API_KEY=your-deepseek-api-key-here

# Alternative: Custom Provider (OpenAI-compatible)
# LLM_PROVIDER=custom
# LLM_MODEL=your-model-name
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://api.your-provider.com/v1
