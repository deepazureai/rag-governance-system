# RAG Evaluation Platform - Frontend Environment Variables

# Node Environment
NODE_ENV=development
PORT=3000

# API Configuration
# For local development: http://localhost:5000
# For Docker compose: http://backend:5000
# For separate servers: http://backend-ip:5000
# For cloud: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# Application Configuration
NEXT_PUBLIC_APP_NAME=RAG Evaluation Metrics Dashboard
NEXT_PUBLIC_APP_VERSION=1.0.0

# Authentication (optional)
# AUTH0_DOMAIN=your-auth0-domain.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret

# Telemetry
NEXT_TELEMETRY_DISABLED=1

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# External Services (optional)
# SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Deployment
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com

# Development only
# NEXT_DEBUG=true

