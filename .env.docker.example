# Docker Compose Environment Variables
# Copy this file to .env and update values for your deployment

# Environment
NODE_ENV=development

# MongoDB Configuration
MONGO_USERNAME=admin
MONGO_PASSWORD=password
MONGO_INITDB_DATABASE=rag-evaluation

# PostgreSQL Configuration
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=rag_evaluation

# Backend Configuration
BACKEND_PORT=5000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://backend:5000

# For production, use full URLs
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# CORS_ORIGIN=https://yourdomain.com

# Database Encryption Key (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-32-character-encryption-key-here

# API Keys and Secrets (add as needed)
# OPENAI_API_KEY=sk-your-key
# SPLUNK_API_KEY=your-key
# DATADOG_API_KEY=your-key

# Session Configuration
SESSION_SECRET=your-session-secret-key-change-in-production

# Local Data Folder (for batch processing)
LOCAL_DATA_FOLDER=/app/local-data

# Optional: For separate deployments
# Update these URLs when running backend and frontend on different servers
# BACKEND_URL=http://backend-server-ip:5000
# FRONTEND_URL=http://frontend-server-ip:3000
