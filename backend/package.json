{
  "name": "rag-evaluation-backend",
  "version": "1.0.0",
  "description": "Node.js backend for RAG LLM Evaluation Platform with pluggable evaluation frameworks",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "node scripts/setup.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "logs": "node scripts/tail-logs.js"
  },
  "keywords": [
    "RAG",
    "LLM",
    "Evaluation",
    "RAGAS",
    "Microsoft Evaluation SDK"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@azure/storage-blob": "^12.12.0",
    "applicationinsights": "^2.9.1",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "mssql": "^9.0.0",
    "mysql2": "^3.2.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.2",
    "pino": "^8.16.2",
    "pino-http": "^8.5.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.6",
    "@types/ws": "^8.5.8",
    "eslint": "^8.51.0",
    "tsx": "^4.0.0",
    "typescript": "^5.2.2"
  }
}
