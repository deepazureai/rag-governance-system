NODE_ENV=development
BACKEND_PORT=5001
DATABASE_URL=mongodb://localhost:27017/rag-evaluation

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# Azure Monitor / Application Insights
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=your-app-insights-key

# Database Encryption Key (for local development only)
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Connector Configuration
RAGAS_ENABLED=true
MICROSOFT_SDK_ENABLED=false

# API Keys
OPENAI_API_KEY=sk-your-openai-key
SPLUNK_API_KEY=your-splunk-key
DATADOG_API_KEY=your-datadog-key

# CORS
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=your-session-secret-key
