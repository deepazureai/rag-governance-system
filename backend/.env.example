PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=sqlite://./data/evaluations.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/rag_evaluation

# Evaluation Frameworks
RAGAS_ENABLED=true
MICROSOFT_SDK_ENABLED=true

# Azure Configuration (for Microsoft SDK)
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=your_endpoint_here
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name

# LLM Configuration for RAGAS
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4-turbo-preview

# WebSocket
WS_PORT=3002
WS_HEARTBEAT_INTERVAL=30000

# CORS
CORS_ORIGIN=http://localhost:3000
