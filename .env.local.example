# MongoDB Credentials
MONGODB_ADMIN_USER=admin
MONGODB_ADMIN_PASSWORD=password
MONGODB_DATABASE=v0_db
MONGODB_URI=mongodb://admin:password@mongodb:27017/v0_db?authSource=admin

# PostgreSQL Credentials (for external database - used by poller)
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=your-pg-user
POSTGRES_PASSWORD=your-pg-password
POSTGRES_DB=your-pg-database

# DeepEval
DEEPEVAL_API_KEY=your-deepeval-api-key

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# Azure OpenAI Configuration (LLM-as-Judge for Hallucination Detection)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_ID=gpt-4

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here

# API Keys
OPENAI_API_KEY=sk-your-key
SPLUNK_API_KEY=your-key
DATADOG_API_KEY=your-key
SESSION_SECRET=your-session-secret

# Application Insights
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=your-app-insights-key
