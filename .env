# Docker Compose Environment Variables
# Complete configuration for all services

# Environment
NODE_ENV=development

# MongoDB Configuration
MONGODB_ADMIN_USER=admin
MONGODB_ADMIN_PASSWORD=password
MONGODB_DATABASE=v0_db
MONGODB_URI=mongodb://admin:password@mongodb:27017/v0_db?authSource=admin

# PostgreSQL Configuration (for batch processing source)
# Use host.docker.internal to connect to external PostgreSQL on local machine from Docker
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=rag_evaluation

# Backend Configuration
BACKEND_PORT=5001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:5001

# Database Encryption Key
ENCRYPTION_KEY=your-32-character-encryption-key-change-in-production

# Azure Configuration (Optional - required for Azure OpenAI recommendations)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_ID=gpt-4

# DeepEval Configuration
DEEPEVAL_API_KEY=test-key-12345678901234567890
DEEPEVAL_ENABLED=true

# Hallucination Detection
HALLUCINATION_DETECTION_ENABLED=true

# Optional: OpenAI API Key (for alternative LLM services)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Other LLM Provider Keys
GROQ_API_KEY=your-groq-key
DEEPSEEK_API_KEY=your-deepseek-key

# Session Configuration
SESSION_SECRET=your-session-secret-key-change-in-production

# Local Data Folder (for batch processing)
LOCAL_DATA_FOLDER=/app/local-data

# Knowledge Base Configuration
KNOWLEDGE_BASE_ENABLED=true
CHROMA_DB_PATH=/app/chroma_db
